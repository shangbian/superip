# 放羊哥综合营销智能体 - 后端环境变量（阿里云部署用）
# 复制为 .env 并填写实际值：cp .env.example .env

PORT=3050
NODE_ENV=production

# Coze API（必填其一）
# 方式一：v3 对话（bot_id）- 与扣子对话页一致
COZE_TOKEN=你的Token
COZE_BOT_ID=7616269899295916066
# 方式二：工作流（workflow_id）- 与原有工作流一致
# COZE_WORKFLOW_ID=7599232922009583626

# 跨域：前端地址，多个用逗号分隔（可与 Nginx 同域时留空或 *）
CORS_ORIGIN=https://markbot.shangbianai.com,http://182.92.97.169:8050,http://localhost:8050
